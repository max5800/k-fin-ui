# API base URL — relative path so the Vite dev-server proxy (or the
# Ingress in-cluster) handles the API routing. Set to an absolute URL
# only when running Vite against a remote API directly.
VITE_API_BASE_URL=/api/v1

# Where Vite's dev-server proxy forwards /api/* requests.
# Override inside the cluster to point at the API service DNS.
VITE_API_PROXY_TARGET=http://localhost:8000

# Set when Vite runs behind a proxy so the HMR client connects to the
# proxy port instead of the internal 3000. Leave empty for localhost dev.
# VITE_HMR_CLIENT_PORT=80
